{
  "name": "snugmark-launcher",
  "version": "1.0.0",
  "description": "Launcher that starts the Snugmark backend and frontend",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "pkg index.js --target node20-win-x64 --output ../snugmark.exe"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.1"
  },
  "pkg": {
    "targets": ["node20-win-x64"],
    "outputPath": ".."
  }
}
